{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "NEWS_API_KEY": "your_news_api_key",
    "NEWS_API_BASE_URL": "https://newsapi.org/v2/everything",
    "NEWS_QUERY": "technology OR finance",
    "NEWS_LANGUAGE": "en",
    "NEWS_SORT_BY": "publishedAt",
    "NEWS_PAGE_SIZE": "100",
    "NEWS_MAX_PAGES": "5",
    "AZURE_STORAGE_CONNECTION_STRING": "DefaultEndpointsProtocol=https;AccountName=...",
    "AZURE_BLOB_CONTAINER": "news-raw",
    "AZURE_SQL_ODBC_CONNECTION_STRING": "Driver={ODBC Driver 18 for SQL Server};Server=tcp:...",
    "AZURE_SQL_TABLE": "dbo.news_articles",
    "LOG_LEVEL": "INFO",
    "KEYWORD_FILTER": "technology,finance,ai,cloud"
  }
}
